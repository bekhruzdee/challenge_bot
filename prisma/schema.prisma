generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum Language {
  uz
  ru
}

enum StoryStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RegistrationStep {
  RULES
  CHECKING_SUB
  INSTAGRAM_SUB
  WAITING_INSTAGRAM_APPROVAL
  ASK_FIRST_NAME
  ASK_LAST_NAME
  ASK_PHONE
  ASK_REGION
}

enum InstagramStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                    Int                    @id @default(autoincrement())
  telegramId            BigInt                 @unique
  telegramUsername      String?
  firstName             String?
  lastName              String?
  phone                 String?
  region                String?
  points                Int                    @default(0)
  isActive              Boolean                @default(true)
  registrationCompleted Boolean                @default(false)
  storyBonusGiven       Boolean                @default(false)
  language              Language?
  stories               StorySubmission[]
  instagramVerification InstagramVerification?
  referrerId            Int?
  referrer              User?                  @relation("UserReferrals", fields: [referrerId], references: [id])
  referrals             User[]                 @relation("UserReferrals")
  session               UserSession?
  locations             Location[]
  progress              Progress[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  lastActivityAt        DateTime?

  @@index([referrerId])
  @@map("users")
}

model UserSession {
  id        Int              @id @default(autoincrement())
  userId    Int              @unique
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  step      RegistrationStep @default(RULES)
  data      Json             @default("{}")
  updatedAt DateTime         @updatedAt

  @@map("user_sessions")
}

model Location {
  id                 Int      @id @default(autoincrement())
  userId             Int
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  latitude           Float
  longitude          Float
  horizontalAccuracy Float?
  recordedAt         DateTime @default(now())

  @@index([userId, recordedAt(sort: Desc)])
  @@map("locations")
}

model StorySubmission {
  id        Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileId    String
  caption   String?
  status    StoryStatus @default(PENDING)
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([status])
  @@map("story_submissions")
}

model InstagramVerification {
  id        Int             @id @default(autoincrement())
  userId    Int             @unique
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileId    String
  status    InstagramStatus @default(PENDING)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@map("instagram_verifications")
}

model BotChat {
  id        Int      @id @default(autoincrement())
  chatId    BigInt   @unique
  title     String
  username  String?
  type      String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bot_chats")
}

model Progress {
  id                     Int       @id @default(autoincrement())
  userId                 Int
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                   DateTime  @db.Date
  totalMeters            Float     @default(0)
  totalSteps             Int       @default(0)
  goalReached            Boolean   @default(false)
  pointsAwarded          Boolean   @default(false)
  lastProgressNotifiedAt DateTime?
  lastSpeedWarningAt     DateTime?

  @@unique([userId, date])
  @@index([userId])
  @@map("daily_progress")
}

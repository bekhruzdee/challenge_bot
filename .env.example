# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Telegram Bot ────────────────────────────────────────────────────────────────
BOT_TOKEN=

# Comma-separated Telegram user IDs that have admin access
ADMIN_IDS=

# Telegram channel the user must subscribe to before registering
CHANNEL_ID=
CHANNEL_LINK=
BOT_USERNAME=

# Instagram channel link shown to users during registration
INSTAGRAM_LINK=

# ── Server ───────────────────────────────────────────────────────────────────────
PORT=
NODE_ENV=

# ── Bot mode ─────────────────────────────────────────────────────────────────────
# polling  – long-polling (default, no public URL required)
# webhook  – Telegram pushes updates via HTTPS (requires WEBHOOK_DOMAIN)
BOT_MODE=

# ── Webhook settings (required only when BOT_MODE=webhook) ───────────────────────
WEBHOOK_DOMAIN=
WEBHOOK_PATH=
# Optional but recommended: secret token to verify requests come from Telegram
WEBHOOK_SECRET_TOKEN=

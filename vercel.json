{
  "version": 2,
  "builds": [
    {
      "src": "dist/src/lambda.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "dist/**",
          "node_modules/.prisma/**",
          "prisma/schema.prisma"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "dist/src/lambda.js" }
  ]
}
